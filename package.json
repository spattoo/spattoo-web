{
  "name": "spattoo-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:marketing": "npm run dev --workspace marketing",
    "dev:app": "npm run dev --workspace app",
    "build:marketing": "npm run build --workspace marketing",
    "build:app": "npm run build --workspace app",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
